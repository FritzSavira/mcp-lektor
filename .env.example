# Required for Langdock (OpenAI-compatible)
LANGDOCK_API_KEY=your_langdock_api_key_here

# Required if using Straico for development
STRAICO_API_KEY=your_straico_api_key_here

# Bible API Settings
BIBLE_API_URL=https://bible-api.com
BIBLE_API_TIMEOUT_SECONDS=5.0

# Server Settings
LOG_LEVEL=info
SERVER_PORT=8080
